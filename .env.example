# SQLite path is relative to the prisma/ folder (creates prisma/dev.db)
DATABASE_URL="file:./dev.db"

# Required for admin session cookies — use a long random string in production
AUTH_SECRET="change-me-to-a-long-random-string"

# Used by seed (npm run db:seed / first npm run dev)
ADMIN_EMAIL="admin@juan.studio"
ADMIN_PASSWORD="juanadmin123"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"
